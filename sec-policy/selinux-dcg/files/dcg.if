########################################
## <summary>
##  Don't audit attempts to memory-map SSSD public files.
## </summary>
## <param name="domain">
##  <summary>
##  Domain allowed access.
##  </summary>
## </param>
#
interface(`dcg_sssd_read_public_files',`
    gen_require(`
        type sssd_public_t;
    ')

    sssd_read_public_files($1)

    dontaudit $1 sssd_public_t:file map;
')
